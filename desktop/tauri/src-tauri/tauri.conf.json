{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ComfyAI",
  "version": "0.1.0",
  "identifier": "com.kenb.comfyai",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
