{
  "manifest_version": 1,
  "comfyui_runtime": {
    "comfyui_repo_source": "https://github.com/comfyanonymous/ComfyUI.git",
    "local_repo_relative_path": "comfyui",
    "python_version_constraints": ">=3.10,<3.13",
    "comfyui_port": 8188,
    "bind_address": "127.0.0.1",
    "venv_path_policy": {
      "mode": "tool_folder",
      "inside_repo_relative_path": ".venv",
      "tool_folder_relative_path": "tools/comfyhybrid-venv",
      "allowed_modes": [
        "inside_repo",
        "tool_folder"
      ]
    }
  },
  "planner_service": {
    "planner_base_url": "http://127.0.0.1:8000",
    "health_endpoint": "/health",
    "can_launch_planner_as_sidecar": true,
    "assistant_repo_path": "",
    "assistant_repo_path_env_var": "COMFYHYBRID_ASSISTANT_REPO"
  },
  "local_planner": {
    "enabled": true,
    "mode": "local",
    "platform_target": "linux",
    "display_name": "Falcon 10B 1.58",
    "default_model_id": "tiiuae/Falcon3-10B-Instruct-1.58bit",
    "role_mapping": {
      "dispatcher_model": "tiiuae/Falcon3-10B-Instruct-1.58bit",
      "planner_model": "tiiuae/Falcon3-10B-Instruct-1.58bit",
      "critic_model": "tiiuae/Falcon3-10B-Instruct-1.58bit"
    },
    "max_repairs_before_fail": 2,
    "request_timeout_seconds": 30,
    "planner_output_dir": "tools/workspace/planner-output",
    "planner_policy_path": "tools/runtime/planner_policy.json",
    "planner_status_path": "tools/runtime/planner_status.json",
    "model_path": "",
    "expected_storage_dir": "tools/models/planner/Falcon3-10B-Instruct-1.58bit",
    "shared_storage_candidates": [
      "/home/ken/Documents/GitHub/BitNet/Falcon3-10B-Instruct-1.58bit",
      "tools/models/planner/Falcon3-10B-Instruct-1.58bit"
    ],
    "model_path_env_vars": [
      "COMFYAI_LOCAL_PLANNER_MODEL",
      "COMFYHYBRID_LOCAL_PLANNER_MODEL"
    ],
    "stronger_model_id": "",
    "escalation_enabled": false
  },
  "linux_workstation": {
    "enabled": true,
    "role": "stable_workstation_development_node",
    "role_label": "stable workstation / development node",
    "machine_label": "Linux stable local generation and fallback node",
    "active_profile": "linux_stable_nvidia",
    "ltx_nodes": {
      "required": true,
      "candidate_paths": [
        "comfyui/custom_nodes/ComfyUI-LTXVideo",
        "comfyui/custom_nodes/LTXVideo",
        "comfyui/custom_nodes/ltxvideo"
      ],
      "source": {
        "kind": "git_url",
        "value": "https://github.com/Lightricks/ComfyUI-LTXVideo.git"
      }
    },
    "preferred_checkpoints": [
      {
        "model_name": "ltx_23_fp8",
        "type": "ltx_checkpoint",
        "acquire_by_default": true,
        "source": {
          "kind": "http_url",
          "value": "https://huggingface.co/Kijai/LTX2.3_comfy/resolve/main/diffusion_models/ltx-2.3-22b-distilled-1.1_transformer_only_fp8_scaled.safetensors"
        },
        "expected_size_min_bytes": 20000000000,
        "sha256": null,
        "target_path_relative_to_models": "diffusion_models/ltx-2.3-22b-distilled-1.1_transformer_only_fp8_scaled.safetensors"
      },
      {
        "model_name": "ltx_23_distilled",
        "type": "ltx_checkpoint",
        "acquire_by_default": false,
        "source": {
          "kind": "http_url",
          "value": "https://huggingface.co/Kijai/LTX2.3_comfy/resolve/main/diffusion_models/ltx-2.3-22b-distilled-1.1_transformer_only_bf16.safetensors"
        },
        "expected_size_min_bytes": 35000000000,
        "sha256": null,
        "target_path_relative_to_models": "diffusion_models/ltx-2.3-22b-distilled-1.1_transformer_only_bf16.safetensors"
      },
      {
        "model_name": "ltx_23_dev",
        "type": "ltx_checkpoint",
        "acquire_by_default": false,
        "source": {
          "kind": "http_url",
          "value": "https://huggingface.co/Kijai/LTX2.3_comfy/resolve/main/diffusion_models/ltx-2.3-22b-dev_transformer_only_bf16.safetensors"
        },
        "expected_size_min_bytes": 35000000000,
        "sha256": null,
        "target_path_relative_to_models": "diffusion_models/ltx-2.3-22b-dev_transformer_only_bf16.safetensors"
      }
    ]
  },
  "optional_comfy_models": [
    {
      "model_name": "sdxl_base.safetensors",
      "type": "checkpoint",
      "source": "local_path",
      "source_value": "",
      "expected_size_min_bytes": 1000000000,
      "sha256": null,
      "target_path_relative_to_models": "checkpoints/sdxl_base.safetensors"
    },
    {
      "model_name": "sdxl_refiner.safetensors",
      "type": "checkpoint",
      "source": "local_path",
      "source_value": "",
      "expected_size_min_bytes": 1000000000,
      "sha256": null,
      "target_path_relative_to_models": "checkpoints/sdxl_refiner.safetensors"
    },
    {
      "model_name": "controlnet_depth.safetensors",
      "type": "controlnet",
      "source": "local_path",
      "source_value": "",
      "expected_size_min_bytes": 100000000,
      "sha256": null,
      "target_path_relative_to_models": "controlnet/controlnet_depth.safetensors"
    },
    {
      "model_name": "example_lora.safetensors",
      "type": "lora",
      "source": "local_path",
      "source_value": "",
      "expected_size_min_bytes": 1000000,
      "sha256": null,
      "target_path_relative_to_models": "loras/example_lora.safetensors"
    }
  ]
}
